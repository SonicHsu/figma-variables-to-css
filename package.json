{
  "dependencies": {
    "@create-figma-plugin/ui": "^4.0.3",
    "@create-figma-plugin/utilities": "^4.0.3",
    "preact": ">=10"
  },
  "devDependencies": {
    "@create-figma-plugin/build": "^4.0.3",
    "@create-figma-plugin/tsconfig": "^4.0.3",
    "@figma/plugin-typings": "1.109.0",
    "@tailwindcss/cli": ">=4",
    "concurrently": ">=9",
    "tailwindcss": ">=4",
    "typescript": ">=5"
  },
  "scripts": {
    "build": "pnpm run build:css && pnpm run build:js",
    "build:css": "npx @tailwindcss/cli --input ./src/input.css --output ./src/output.css",
    "build:js": "build-figma-plugin --typecheck --minify",
    "watch": "pnpm run build:css && concurrently pnpm:watch:css pnpm:watch:js",
    "watch:css": "npx @tailwindcss/cli --input ./src/input.css --output ./src/output.css --watch",
    "watch:js": "build-figma-plugin --typecheck --watch",
    "proxy": "node proxy/server.js"
  },
  "figma-plugin": {
    "editorType": [
      "figma"
    ],
    "id": "preact-tailwindcss",
    "name": "Preact Tailwind Css",
    "main": "src/main.ts",
    "ui": "src/ui.tsx",
    "networkAccess": {
      "allowedDomains": [
        "*"
      ],
      "reasoning": "Needs to connect to self-hosted GitLab instances to commit design token CSS files via the GitLab API."
    }
  }
}